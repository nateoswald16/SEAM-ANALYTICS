# ═══════════════════════════════════════════════════════════════
# Seam Analytics — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
venv_backup*/

# ── Databases (too large for Git — ship via installer) ────────
*.db
*.db-shm
*.db-wal
*.db-journal
*.schema_version

# ── Caches & runtime data ────────────────────────────────────
*.pkl
*.log
app/temp_lineups_cache.json
app/assets/lineup_cache/
app/assets/weather_cache/
app/assets/logos/
app/statcast_cache/

# ── Installer build artifacts ─────────────────────────────────
build/
dist/
installer/output/

# ── OS junk ───────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store
nul

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── One-time repair / utility scripts ─────────────────────────
app/backfill_*.py
app/verify_2025.py
app/rebuild_2026.py
app/backfill_outs_er.py
app/download_historical_statcast.py

# ── API keys ──────────────────────────────────────────────────
app/weatherapi_key.txt
app/assets/headshots/
app/player_ids_cache.json
app/processed_dates_cache.json
